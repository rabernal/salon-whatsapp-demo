# Copy this file to ".env" and fill in your key to enable LIVE mode (real Claude).
# Leave ANTHROPIC_API_KEY empty to run in offline MOCK mode (no key needed).

ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-haiku-4-5-20251001
PORT=3000

# ---- WhatsApp Cloud API (optional) ----
# Leave these blank to run the web demo only. Fill them to enable the WhatsApp
# webhook + reminders. See WHATSAPP.md for how to get each value.
WHATSAPP_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_VERIFY_TOKEN=
WHATSAPP_APP_SECRET=
GRAPH_API_VERSION=v21.0
# Map the test number above to one seeded salon during local testing:
WHATSAPP_DEFAULT_SALON=studio-bella
# Reminders: leave template blank to send plain text (only works inside 24h window).
# In production set an approved template name + its language code:
WHATSAPP_REMINDER_TEMPLATE=
WHATSAPP_TEMPLATE_LANG=es
